{
  "name": "codelab",
  "displayName": "Codelab",
  "description": "AI-powered code pattern extraction, conformance checking, and deep analysis — powered by Claude Code CLI",
  "version": "0.0.1",
  "publisher": "BrianMwangi",
  "author": {
    "name": "Brian Mwangi",
    "url": "https://brianmwangi.dev"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianmwangi/codelab"
  },
  "homepage": "https://brianmwangi.dev",
  "icon": "media/codelab-icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "code quality",
    "linting",
    "patterns",
    "conformance",
    "claude",
    "ai",
    "code review",
    "deep analysis"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codelab.countFiles",
        "title": "Codelab: Count Workspace Files"
      },
      {
        "command": "codelab.extractPatterns",
        "title": "Codelab: Extract Patterns"
      },
      {
        "command": "codelab.checkConformance",
        "title": "Codelab: Check Code Conformance"
      },
      {
        "command": "codelab.refreshIssues",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "codelab.togglePushGuard",
        "title": "Codelab: Toggle Push Guard",
        "icon": "$(lock)"
      },
      {
        "command": "codelab.runDeepAnalysis",
        "title": "Codelab: Run Deep Analysis",
        "icon": "$(beaker)"
      },
      {
        "command": "codelab.configureScope",
        "title": "Codelab: Configure File Scope",
        "icon": "$(filter)"
      },
      {
        "command": "codelab.ignoreInCodelab",
        "title": "Codelab: Ignore in Analysis"
      },
      {
        "command": "codelab.toggleScopeMode",
        "title": "Codelab: Toggle Scope Mode",
        "icon": "$(arrow-swap)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codelab-sidebar",
          "title": "Codelab",
          "icon": "media/codelab-icon.svg"
        }
      ]
    },
    "views": {
      "codelab-sidebar": [
        {
          "id": "codelab.issuesView",
          "name": "Pattern Issues",
          "icon": "media/codelab-icon.svg"
        },
        {
          "id": "codelab.scopeView",
          "name": "File Scope"
        },
        {
          "id": "codelab.analysisView",
          "name": "Deep Analysis"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codelab.checkConformance",
          "when": "view == codelab.issuesView",
          "group": "navigation"
        },
        {
          "command": "codelab.refreshIssues",
          "when": "view == codelab.issuesView",
          "group": "navigation"
        },
        {
          "command": "codelab.togglePushGuard",
          "when": "view == codelab.issuesView",
          "group": "navigation"
        },
        {
          "command": "codelab.configureScope",
          "when": "view == codelab.issuesView",
          "group": "navigation"
        },
        {
          "command": "codelab.toggleScopeMode",
          "when": "view == codelab.scopeView",
          "group": "navigation"
        },
        {
          "command": "codelab.runDeepAnalysis",
          "when": "view == codelab.analysisView",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "codelab.ignoreInCodelab",
          "group": "codelab@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
